<configuration name="event_socket.conf" description="Socket Client">
  <settings>
    <param name="nat-map" value="false"/>
    <!--
      Binding ESL to 127.0.0.1 only works when FreeSWITCH shares the host
      network namespace (for example, Docker host networking). In bridged or
      other non-host-networked container deployments, peers in other
      containers cannot connect unless this is changed to 0.0.0.0.
    -->
    <param name="listen-ip" value="127.0.0.1"/>
    <param name="listen-port" value="8021"/>
    <param name="password" value="ClueCon"/>
    <param name="stop-on-bind-error" value="true"/>
  </settings>
</configuration>
